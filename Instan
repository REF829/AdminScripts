-- start --
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TeleportService")
local Player = game:GetService("Players").LocalPlayer
local Camera = workspace.CurrentCamera
local Flying = false
local Noclipping = false
local moveKeysDown = {
	W = false,
	A = false,
	S = false,
	D = false,
}
local keyMap = {
	[Enum.KeyCode.W] = "W",
	[Enum.KeyCode.A] = "A",
	[Enum.KeyCode.S] = "S",
	[Enum.KeyCode.D] = "D",
}

-- main functions --
local function canUseMovement()
	if UIS:GetFocusedTextBox() then
		return false
	end
	return true
end
UIS.InputBegan:Connect(function(input, gameProcessedEvent)
	if gameProcessedEvent then return end
	local name = keyMap[input.KeyCode]
	if name and canUseMovement() then
		moveKeysDown[name] = true
	end
end)
UIS.InputEnded:Connect(function(input, gameProcessedEvent)
	local name = keyMap[input.KeyCode]
	if name then
		moveKeysDown[name] = false
	end
end)
local function fly()
	Flying = not Flying

	if Flying then
		local char = Player.Character
		local rootPart:BasePart = char:WaitForChild("HumanoidRootPart")
		local hum:Humanoid = char:WaitForChild("Humanoid")
		hum.PlatformStand = true
		local currentCF = rootPart.CFrame

		while Flying and task.wait() do
			local add = Vector3.new(0, 0, 0)

			if moveKeysDown.W and canUseMovement() then add += Camera.CFrame.LookVector end
			if moveKeysDown.S and canUseMovement() then add -= Camera.CFrame.LookVector end
			if moveKeysDown.D and canUseMovement() then add += Camera.CFrame.RightVector end
			if moveKeysDown.A and canUseMovement() then add -= Camera.CFrame.RightVector end

			rootPart.AssemblyLinearVelocity = Vector3.zero
			rootPart.AssemblyAngularVelocity = Vector3.zero

			currentCF += add
			rootPart.CFrame = CFrame.lookAt(
				currentCF.Position,
				currentCF.Position + (Camera.CFrame.LookVector * 2)
			)
		end

		hum.PlatformStand = false
	end
end
local function noclip()
	if Noclipping then
		if Player.Character.Humanoid.RigType == Enum.HumanoidRigType.R15 then
			Player.Character.LowerTorso.CanCollide = false
			Player.Character.UpperTorso.CanCollide = false
			Player.Character.HumanoidRootPart.CanCollide = false
			Player.Character.HumanoidRootPart.CanQuery = false
		elseif Player.Character.Humanoid.RigType == Enum.HumanoidRigType.R6 then
			Player.Character.Torso.CanCollide = false
			Player.Character.Humanoid.CanQuery = false
		end
	end
	if not Noclipping then
		if Player.Character.Humanoid.RigType == Enum.HumanoidRigType.R15 then
			Player.Character.LowerTorso.CanCollide = true
			Player.Character.UpperTorso.CanCollide = true
			Player.Character.HumanoidRootPart.CanCollide = true
			Player.Character.HumanoidRootPart.CanQuery = true
		elseif Player.Character.Humanoid.RigType == Enum.HumanoidRigType.R6 then
			Player.Character.Torso.CanCollide = true
			Player.Character.Torso.CanQuery = true
		end
	end
end
local function reset()
	local Character = Player.Character
	local Humanoid = Character.Humanoid
	Humanoid.Health = 0
end
local function rejoin()
	local placeId = game.PlaceId
	local jobId = game.JobId
	TS:TeleportToPlaceInstance(placeId, jobId, Player)
end
local function sit()
	if game.Players.LocalPlayer.Character.Humanoid then
		game.Players.LocalPlayer.Character.Humanoid.Sit = true
	end
end
local function cmds()
	CMDSUI.Enabled = not CMDSUI.Enabled
end

-- chat commands --
Player.Chatted:Connect(function(MSG)
	if MSG == "[fly]" then
		fly()
	elseif MSG == "[unfly]" then
		Flying = false
	end
end)
Player.Chatted:Connect(function(MSG)
	if MSG == "[rs]" or MSG == "[reset]" then
		reset()
	end
end)
Player.Chatted:Connect(function(MSG)
	if MSG == "[rj]" or MSG == "[rejoin]" then
		rejoin()
	end
end)
Player.Chatted:Connect(function(MSG)
	if MSG == "[noclip]" then
		Noclipping = true
		noclip()
	elseif MSG == "[clip]" then
		Noclipping = false
		noclip()
	end
end)
Player.Chatted:Connect(function(MSG)
	if MSG == "[cmds]" then
		cmds()
	end
end)
Player.CharacterAdded:Connect(function()
	Flying = false
end)
