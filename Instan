local UIS = game:GetService("UserInputService")
local TS = game:GetService("TeleportService")
local Player = game:GetService("Players").LocalPlayer
local Camera = workspace.CurrentCamera
local Flying = false
local moveKeysDown = {
    W = false,
    A = false,
    S = false,
    D = false,
}
local keyMap = {
    [Enum.KeyCode.W] = "W",
    [Enum.KeyCode.A] = "A",
    [Enum.KeyCode.S] = "S",
    [Enum.KeyCode.D] = "D",
}

local function canUseMovement()
    if UIS:GetFocusedTextBox() then
        return false
    end
    return true
end
UIS.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    local name = keyMap[input.KeyCode]
    if name and canUseMovement() then
        moveKeysDown[name] = true
    end
end)
UIS.InputEnded:Connect(function(input, gameProcessedEvent)
    local name = keyMap[input.KeyCode]
    if name then
        moveKeysDown[name] = false
    end
end)
local function toggleFly()
    Flying = not Flying

    if Flying then
        local char = Player.Character
        local rootPart:BasePart = char:WaitForChild("HumanoidRootPart")
        local hum:Humanoid = char:WaitForChild("Humanoid")
        hum.PlatformStand = true
        local currentCF = rootPart.CFrame

        while Flying and task.wait() do
            local add = Vector3.new(0, 0, 0)

            if moveKeysDown.W and canUseMovement() then add += Camera.CFrame.LookVector end
            if moveKeysDown.S and canUseMovement() then add -= Camera.CFrame.LookVector end
            if moveKeysDown.D and canUseMovement() then add += Camera.CFrame.RightVector end
            if moveKeysDown.A and canUseMovement() then add -= Camera.CFrame.RightVector end

            rootPart.AssemblyLinearVelocity = Vector3.zero
            rootPart.AssemblyAngularVelocity = Vector3.zero

            currentCF += add
            rootPart.CFrame = CFrame.lookAt(
                currentCF.Position,
                currentCF.Position + (Camera.CFrame.LookVector * 2)
            )
        end

        hum.PlatformStand = false
    end
end
local function reset()
    local Character = Player.Character
    local Humanoid = Character.Humanoid
    Humanoid.Health = 0
end
local function refresh()
    local ws=game.Workspace
    local char=game.Players.LocalPlayer.Character
    local newChar = Instance.new("Model")
    newChar.Parent = workspace
    newChar.Name="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    if char:FindFirstChildOfClass("Humanoid") then char:FindFirstChildOfClass("Humanoid"):ChangeState(15) end
    char:ClearAllChildren()
    game.Players.LocalPlayer.Character = newChar
    if ws then
        dele=ws:WaitForChild(char.Name)
        if dele then
            dele:Destroy()
        end
    end
    game.Players.LocalPlayer.Character = char
    wait(.1)
    newChar:Destroy()
end
local function Rejoin()
    local placeId = game.PlaceId
    local jobId = game.JobId
    TS:TeleportToPlaceInstance(placeId, jobId, Player)
end

Player.Chatted:Connect(function(MSG)
    if MSG == "[fly]" then
        toggleFly()
    elseif MSG == "[unfly]" then
        Flying = false
    end
end)
Player.Chatted:Connect(function(MSG)
    if MSG == "[rs]" then
        reset()
    end
end)
Player.Chatted:Connect(function(MSG)
    if MSG == "[re]" then
        refresh()
    end
end)
Player.Chatted:Connect(function(MSG)
    if MSG == "[rj]" then
        Rejoin()
    end
end)
Player.CharacterAdded:Connect(function()
  Flying = false
end)
